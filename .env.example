# ============================================================
# Happy Baby – Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Anthropic AI Chat (existing)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Supabase (Phase 2+3: Backend & Auth)
# Get these from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (Phase 4: Payments)
# Get these from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_test_your-publishable-key
VITE_STRIPE_PRICE_ID=price_your-price-id

# Stripe secret key (used in Supabase Edge Function, not in frontend)
# STRIPE_SECRET_KEY=sk_test_your-secret-key
